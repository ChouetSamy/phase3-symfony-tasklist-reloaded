<div class="min-h-screen flex items-center justify-center bg-gradient-to-r from-gray-200 to-blue-200">

	<div class="bg-white p-8 rounded-2xl shadow w-96">

		<h2 class="text-lg font-semibold mb-2">Gestion de Tâches</h2>
		<p class="text-sm text-gray-500 mb-4">
			Organisez votre journée efficacement
		</p>


		<div class="flex mb-4 bg-gray-100 rounded-full p-1">

			<a href="{{ path('app_login') }}" class="w-1/2 text-center py-1 rounded-full
					       {{ app.request.attributes.get('_route') == 'app_login'
					            ? 'bg-white shadow'
					            : '' }}">
				Connexion
			</a>

			<a href="{{ path('app_register') }}" class="w-1/2 text-center py-1 rounded-full
					       {{ app.request.attributes.get('_route') == 'app_register'
					            ? 'bg-white shadow'
					            : '' }}">
				Inscription
			</a>

		</div>

		<form method="post">

			<div class="mb-3">
				<label>Email</label>
				<input type="email" name="email" class="w-full p-2 rounded bg-gray-100" placeholder="votre@email.com">
			</div>

			<div class="mb-3">
				<label>Nom d'utilisateur</label>
				<input type="text" name="username" class="w-full p-2 rounded bg-gray-100" placeholder="nom_utilisateur">
			</div>

			<div class="mb-4">
				<label>Mot de passe</label>
				<input type="password" name="password" class="w-full p-2 rounded bg-gray-100" placeholder="•••••••">
			</div>

			<button class="w-full bg-black text-white py-2 rounded">
				S'inscrire
			</button>

		</form>

	</div>

</div>
