<div class="flex justify-between items-center bg-white p-4 gap-12 rounded shadow">

	<div class="flex items-center gap-3">
		<div>
			<div class="flex flex-row">
				<p class="font-medium mr-2">{{ task.title }}</p>
				<form method="post" action="{{ path('app_task_status', { id: task.id }) }}">

					<input type="hidden" name="_token" value="{{ csrf_token('status' ~ task.id) }}">

					<select name="status" onchange="this.form.submit()" class="border p-1 rounded">

						<option value="pending" {% if task.status.value == 'pending' %} selected {% endif %}>
							🟡 En cours
						</option>

						<option value="completed" {% if task.status.value == 'completed' %} selected {% endif %}>
							🟢 Completé
						</option>

						<option value="archived" {% if task.status.value == 'archived' %} selected {% endif %}>
							📦 Archivé
						</option>

					</select>

				</form>
			</div>
			<p class="text-sm text-gray-500">
				{{ task.priorities.name }}
			</p>
		</div>

	</div>

	<div class="flex gap-3">

		<form method="post" action="{{ path('app_dashboard_pin', { id: task.id })}}">
			<input type="hidden" name="_token" value="{{ csrf_token('pin' ~ task.id) }}">

			<button>
				{% if task.isPinned %}
					📌
				{% else %}
					📍
				{% endif %}
			</button>
		</form>

		<a href="{{ path('app_task_edit', { id: task.id }) }}">
			✏️ Editer
		</a>
		<form method="post" action="{{ path('app_task_delete', { id: task.id })}}" onsubmit="return confirm('Are you sure you want to delete this item?')">
			<input type="hidden" name="_token" value="{{ csrf_token('delete' ~ task.id) }}">
			<button class="text-red-500">❌ Supprimer</button>
		</form>

	</div>

</div>
