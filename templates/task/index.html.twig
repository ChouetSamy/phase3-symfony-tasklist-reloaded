{% extends 'base.html.twig' %}

{% block title %}Toutes les tâches
{% endblock %}

{% block body %}

	<div
		class="min-h-screen bg-gray-100 p-8">

		{# HEADER #}
		<div class="flex justify-between items-center mb-6">
			<h1 class="text-2xl font-bold">Toutes les tâches</h1>
			<a href="{{ path('app_dashboard') }}" class="bg-gray-200 px-4 py-2 rounded">
				Retour Vers le dashboard
			</a>

			<a href="{{ path('app_priority_index')}}" class="px-3 py-2 bg-gray-200 rounded">
				⚙️ Gérer les priorités
			</a>

			<a href="{{ path('app_folder_new')}}" class="px-3 py-2 bg-gray-200 rounded">
				📁 Nouveau dossier
			</a>

			<a href="{{ path('app_task_new')}}" class="px-3 py-2 bg-black text-white rounded">
				➕ Nouvelle tâche
			</a>

			<a href="{{ path('app_logout')}}" class="px-3 py-2 bg-gray-200 rounded">
				🚪 Déconnexion
			</a>

		</div>


		<div class="space-y-4">

			{% for task in tasks %}

				<div class="flex justify-between items-center bg-white p-4 rounded shadow">

					<div class="flex items-center gap-4">

						<input type="checkbox" {% if task.isPinned %} checked {% endif %}>

						<div>
							<p class="font-medium">{{ task.title }}</p>

							<p class="text-sm text-gray-500">
								📁
								{{ task.folder.name }}
								•
								{{ task.status.value }}
								{% if task.priorities %}
									•
									{{ task.priorities.name }}
								{% endif %}
							</p>
						</div>

					</div>

					<div class="flex items-center gap-3">

						<form method="post" action="{{ path('app_task_pin', { id: task.id })}}">
							<input type="hidden" name="_token" value="{{ csrf_token('pin' ~ task.id) }}">

							<button>
								{% if task.isPinned %}
									📌
								{% else %}
									📍
								{% endif %}
							</button>
						</form>

						<a href="{{ path('app_task_edit', { id: task.id }) }}">
							✏️ Editer
						</a>

						<form method="post" action="{{ path('app_task_delete', { id: task.id })}}" onsubmit="return confirm('Are you sure you want to delete this item?')">
							<input type="hidden" name="_token" value="{{ csrf_token('delete' ~ task.id) }}">
							<button class="text-red-500">❌ Supprimer</button>
						</form>

					</div>

				</div>

			{% else %}

				<div class="text-center text-gray-500">
					Aucune tâche trouvée
				</div>

			{% endfor %}

		</div>

	</div>

{% endblock %}
